<!-- 🔹 HERO SECTION -->
<section class="gallery-hero">
    <div class="gallery-hero-content">
        <h1 class="gallery-title">Visual Journey</h1>
        <p class="gallery-subtitle">
            A collection of moments from global seminars, lab research, and tech mentorship programs.
        </p>
    </div>
</section>

<!-- 🔹 GALLERY BODY -->
<section class="gallery-body bg-light-cream">
    <div class="gallery-masonry-container">

        @{
            var index = 0;
        }

        @foreach (var item in Model)
        {
            var cssClass = "masonry-item";

            if (index % 5 == 0)
            {
                cssClass += " tall";
            }
            else if (index % 3 == 0)
            {
                cssClass += " wide";
            }

            <div class="@cssClass">
                <img src="@item.ImageUrl"
                     alt="@item.Title"
                     class="masonry-img organic-image-soft" />

                <div class="masonry-overlay glass-card">
                    <h3>@item.Title</h3>
                    <p>@item.Description</p>
                </div>
            </div>

            index++;
        }

    </div>
</section>

<!-- 🔥 OPTIONAL: EMPTY STATE -->
@if (Model == null || !Model.Any())
{
    <div class="text-center p-5">
        <h4>No images found</h4>
        <p class="text-muted">Upload images from admin panel</p>
    </div>
}