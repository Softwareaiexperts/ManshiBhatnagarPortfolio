        <div class="blog-feed">

            @foreach (var item in Model.Articles)
            {
                <article class="blog-post-card">
                    <div class="blog-img-wrapper">
                        <img src="@item.ImageUrl" alt="@item.Title">
                    </div>

                    <div class="blog-post-content">
                        <span class="blog-tag">@item.Category?.ToUpper()</span>

                        <a href="/Home/BlogDetail/@item.Id" class="blog-post-title">
                            @item.Title
                        </a>

                        @{
                            var cleanContent = item.Content != null ? System.Text.RegularExpressions.Regex.Replace(item.Content, "<.*?>", string.Empty) : "";
                            var excerpt = cleanContent.Length > 150 ? cleanContent.Substring(0, 150) + "..." : cleanContent;
                        }
                        <p class="blog-post-excerpt">@excerpt</p>

                        <div class="blog-meta">
                            <span>
                                By @item.Author • @item.CreatedDate.ToString("MMM dd, yyyy")
                            </span>

                            <a href="/Home/BlogDetail/@item.Id" class="blog-read-more">
                                Read Full Post →
                            </a>
                        </div>
                    </div>
                </article>
                        }

        </div>
        <!-- RIGHT COLUMN: Sidebar -->
        <aside class="blog-sidebar">

