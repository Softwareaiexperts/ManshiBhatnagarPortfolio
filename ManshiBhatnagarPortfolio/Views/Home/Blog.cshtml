                </ul> *@
                <ul class="latest-blogs-list">

                    @foreach (var item in Model.Articles.Take(4))
                    {
                        <li class="latest-blog-item">
                            <img src="@item.ImageUrl" class="latest-blog-img" alt="Blog Thumb">

                            <div class="latest-blog-info">
                                <h4>
                                    <a href="/Home/BlogDetail/@item.Id">
                                        @item.Title
                                    </a>
                                </h4>

                                <span>@item.CreatedDate.ToString("MMM dd, yyyy")</span>
                            </div>
                        </li>
                    }

                </ul>
            </div>

            <!-- Categories Widget -->
            @* <div class="sidebar-widget">
                    <h3 class="widget-title">Categories</h3>
                    <ul class="list-unstyled" style="line-height:2.2;">
                        <li><a href="#" style="color:#555; text-decoration:none;">&#8594; Deep Learning (12)</a></li>
                        <li><a href="#" style="color:#555; text-decoration:none;">&#8594; Cyber Security (8)</a></li>
                        <li><a href="#" style="color:#555; text-decoration:none;">&#8594; Smart Grids (5)</a></li>
                        <li><a href="#" style="color:#555; text-decoration:none;">&#8594; Academia & Mentorship (14)</a></li>
                    </ul>
                </div> *@
            <div class="sidebar-widget">
                <h3 class="widget-title">Categories</h3>

                <ul class="list-unstyled" style="line-height:2.2;">

                    <li>
                        <a href="/Home/Blog"
                           style="color:@(Model.SelectedCategory == null ? "#000" : "#555"); font-weight:bold; text-decoration:none;">
                            → All (@Model.Articles.Count)
                        </a>
                    </li>

                    @foreach (var cat in Model.Categories)
                    {
                        <li>
                            <a href="/Home/Blog?category=@cat.Name"
                               style="color:@(Model.SelectedCategory == cat.Name ? "#000" : "#555");
                                  font-weight:@(Model.SelectedCategory == cat.Name ? "bold" : "normal");
                                  text-decoration:none;">

                                → @cat.Name (@cat.Count)
                            </a>
                        </li>
                    }

                </ul>
            </div>
        </aside>

    </div>
</section>
