@model BlogPageViewModel
@{
    ViewData["Title"] = "Blog";
}
<link href="~/css/BlogPage.css" rel="stylesheet" />

<!-- Hero Section -->
<section class="hero-blog">
    <div class="hero-blog-content">
        <h1 class="hero-blog-title">Tech & Innovation Blog</h1>
        <p class="hero-blog-subtitle">Insights on Artificial Intelligence, Smart Grids, and Cybersecurity.</p>
    </div>
    <div class="custom-shape-divider-bottom">
        <svg data-name="Layer 1" xmlns="http://w3.org" viewBox="0 0 1200 120" preserveAspectRatio="none">
            <path d="M985.66,92.83C906.67,72,823.78,31,743.84,14.19c-82.26-17.34-168.06-16.33-250.45.39-57.84,11.73-114,31.07-172,41.86A600.21,600.21,0,0,1,0,27.35V120H1200V95.8C1132.19,118.92,1055.71,111.31,985.66,92.83Z" fill="#f8f9fa"></path>
        </svg>
    </div>
</section>

