@{
    ViewData["Title"] = "Curriculum Vitae";
}
<link href="~/css/CVPage.css" rel="stylesheet" />

<section class="cv-hero">
    <div class="cv-hero-content">
        <h1 class="cv-title">Curriculum Vitae</h1>
        <p class="cv-subtitle">A journey of academic research, technological innovation, and continuous learning.</p>
        <a href="#" class="btn-download-cv">Download Full PDF</a>
    </div>
</section>

<section class="cv-body bg-light-cream">
    <div class="cv-container">

        <!-- Interactive Timeline Column -->
        <div class="cv-timeline-column">

            <h2 class="cv-section-header">Education</h2>
            <div class="timeline">
                <div class="timeline-item glass-card">
                    <div class="timeline-dot"></div>
                    <span class="timeline-date">2022 - Present</span>
                    <h3>Ph.D. in Deep Learning & Smart Grids</h3>
                    <h4>Slovak University of Technology</h4>
                    <p>Focusing on short-term electric load forecasting (STLF) using advanced meta-heuristic algorithms and Temporal Convolutional Networks.</p>
                </div>

                <div class="timeline-item glass-card">
                    <div class="timeline-dot"></div>
                    <span class="timeline-date">2018 - 2020</span>
                    <h3>MTech in Cyber Security</h3>
                    <h4>Global Technology Institute</h4>
                    <p>Specialized in deep network threat modeling, IoT vulnerabilities, and secure data distribution algorithms.</p>
                </div>
            </div>

            <h2 class="cv-section-header mt-5">Experience</h2>
            <div class="timeline">
                <div class="timeline-item glass-card">
                    <div class="timeline-dot"></div>
                    <span class="timeline-date">2023 - Present</span>
                    <h3>Primary AI Researcher</h3>
                    <h4>International Smart Grid Consortium</h4>
                    <p>Leading analysis on load balancing models and publishing iterative findings in core engineering journals. Developing predictive data architectures.</p>
                </div>

                <div class="timeline-item glass-card">
                    <div class="timeline-dot"></div>
                    <span class="timeline-date">2020 - 2022</span>
                    <h3>Data Scientist</h3>
                    <h4>Tech Infrastructure Partners</h4>
                    <p>Designed anomaly detection prototypes for municipal energy setups to detect and mitigate usage spikes effectively.</p>
                </div>
            </div>
        </div>

        <!-- Skills and Highlights Column -->
        <div class="cv-sidebar-column">

            <div class="skilss-block glass-card">
                <h3 class="sidebar-title">Core Competencies</h3>

                <div class="skill-item">
                    <span>Artificial Intelligence / ML</span>
                    <div class="progress-bar"><div class="progress-fill" style="width: 95%;"></div></div>
                </div>

                <div class="skill-item">
                    <span>Neural Networks & PyTorch</span>
                    <div class="progress-bar"><div class="progress-fill" style="width: 92%;"></div></div>
                </div>

                <div class="skill-item">
                    <span>Image Processing & CV</span>
                    <div class="progress-bar"><div class="progress-fill" style="width: 88%;"></div></div>
                </div>

                <div class="skill-item">
                    <span>Smart Grid Optimization</span>
                    <div class="progress-bar"><div class="progress-fill" style="width: 90%;"></div></div>
                </div>
            </div>

            <div class="awards-block glass-card mt-4">
                <h3 class="sidebar-title">Recent Publications</h3>
                <ul class="pub-list">
                    <li><strong>Using Crafted Features and Polar Bear Optimization Algorithm for STLF</strong><br /><em>2024</em></li>
                    <li><strong>Web Intrusion Classification System using Machine Learning</strong><br /><em>2022</em></li>
                    <li><strong>Comprehensive Electric load forecasting using ensemble methods</strong><br /><em>2022</em></li>
                    <li><strong>STLF Using Random Forest with Entropy-Based Feature Selection</strong><br /><em>2022</em></li>
                    <li><strong>AI in Agriculture: Efficient Plant Disease Detection</strong><br /><em>2022</em></li>
                </ul>
            </div>

        </div>

    </div>
</section>
    