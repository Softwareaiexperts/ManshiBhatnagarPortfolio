@{
    ViewData["Title"] = "Curriculum Vitae";
    var s = (Dictionary<string, string>)ViewBag.Sections;
}
<link href="~/css/CVPage.css" rel="stylesheet" />

<section class="cv-hero">
    <div class="cv-hero-content">
        <h1 class="cv-title">@s.GetValueOrDefault("cv_hero_title", "Curriculum Vitae")</h1>
        <p class="cv-subtitle">@s.GetValueOrDefault("cv_hero_subtitle", "")</p>
        <a href="@s.GetValueOrDefault("cv_download_url", "#")" class="btn-download-cv">Download Full PDF</a>
    </div>
</section>

<section class="cv-body bg-light-cream">
    <div class="cv-container">

        <!-- Interactive Timeline Column -->
        <div class="cv-timeline-column">

            <h2 class="cv-section-header">Education</h2>
            <div class="timeline">
                @for (int i = 1; i <= 2; i++)
                {
                    var date = s.GetValueOrDefault($"cv_edu_{i}_date", "");
                    var title = s.GetValueOrDefault($"cv_edu_{i}_title", "");
                    var inst = s.GetValueOrDefault($"cv_edu_{i}_institution", "");
                    var desc = s.GetValueOrDefault($"cv_edu_{i}_desc", "");
                    if (!string.IsNullOrEmpty(title))
                    {
                        <div class="timeline-item glass-card">
                            <div class="timeline-dot"></div>
                            <span class="timeline-date">@date</span>
                            <h3>@title</h3>
                            <h4>@inst</h4>
                            <p>@desc</p>
                        </div>
                    }
                }
            </div>

            <h2 class="cv-section-header mt-5">Experience</h2>
            <div class="timeline">
                @for (int i = 1; i <= 2; i++)
                {
                    var date = s.GetValueOrDefault($"cv_exp_{i}_date", "");
                    var title = s.GetValueOrDefault($"cv_exp_{i}_title", "");
                    var company = s.GetValueOrDefault($"cv_exp_{i}_company", "");
                    var desc = s.GetValueOrDefault($"cv_exp_{i}_desc", "");
                    if (!string.IsNullOrEmpty(title))
                    {
                        <div class="timeline-item glass-card">
                            <div class="timeline-dot"></div>
                            <span class="timeline-date">@date</span>
                            <h3>@title</h3>
                            <h4>@company</h4>
                            <p>@desc</p>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Skills and Highlights Column -->
        <div class="cv-sidebar-column">

            <div class="skilss-block glass-card">
                <h3 class="sidebar-title">Core Competencies</h3>
                @for (int i = 1; i <= 4; i++)
                {
                    var skillName = s.GetValueOrDefault($"cv_skill_{i}_name", "");
                    var skillPercent = s.GetValueOrDefault($"cv_skill_{i}_percent", "0");
                    if (!string.IsNullOrEmpty(skillName))
                    {
                        <div class="skill-item">
                            <span>@skillName</span>
                            <div class="progress-bar"><div class="progress-fill" style="width: @(skillPercent)%;"></div></div>
                        </div>
                    }
                }
            </div>

            <div class="awards-block glass-card mt-4">
                <h3 class="sidebar-title">Recent Publications</h3>
                <div class="pub-list">
                    @Html.Raw(s.GetValueOrDefault("cv_publications_html", ""))
                </div>
            </div>

        </div>

    </div>
</section>