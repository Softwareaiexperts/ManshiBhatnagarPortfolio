@model ManshiBhatnagarPortfolio.Models.ContactMessage
@{
    ViewData["Title"] = "Contact";
}
<link href="~/css/ContactPage.css" rel="stylesheet" />

<!-- Hero Section -->
<section class="hero-contact">
    <div class="hero-contact-content">
        <h1 class="hero-contact-title">Let's Get in Touch</h1>
        <p class="hero-contact-subtitle">Whether you have a question about my research, or just want to say hi, I'll try my best to get back to you.</p>
    </div>
    <div class="custom-shape-divider-bottom">
        <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
            <path d="M985.66,92.83C906.67,72,823.78,31,743.84,14.19c-82.26-17.34-168.06-16.33-250.45.39-57.84,11.73-114,31.07-172,41.86A600.21,600.21,0,0,1,0,27.35V120H1200V95.8C1132.19,118.92,1055.71,111.31,985.66,92.83Z" fill="#f8f9fa"></path>
        </svg>
    </div>
</section>

<!-- Contact Layout -->
<section class="contact-page-bg">
    <div class="contact-container">

        <!-- LEFT COLUMN: Contact Information -->
        <div class="contact-info-column">
            <h2>Contact Information</h2>
            <p class="mb-5">
                I am actively seeking collaborations in AI, open to speaking at academic seminars, and always happy to discuss smart grid optimization challenges. Feel free to reach out via the form, or follow me on my professional portals.
            </p>

            <div class="info-card">
                <div class="info-icon">
                    <span>&#9993;</span> <!-- Simple mail icon -->
                </div>
                <div class="info-text">
                    <h4>Direct Email</h4>
                    <p><a href="mailto:contact@mansibhatnagar.com">contact@mansibhatnagar.com</a></p>
                </div>
            </div>

            <div class="info-card">
                <div class="info-icon">
                    <span>&#128188;</span> <!-- Simple briefcase icon -->
                </div>
                <div class="info-text">
                    <h4>LinkedIn</h4>
                    <p><a href="#">Connect professionally</a></p>
                </div>
            </div>

            <div class="info-card">
                <div class="info-icon">
                    <span>&#128218;</span> <!-- Simple book icon -->
                </div>
                <div class="info-text">
                    <h4>Google Scholar & ResearchGate</h4>
                    <p><a href="https://scholar.google.com/citations?user=3ii2fPEAAAAJ&hl=en" target="_blank">View my public citations</a></p>
                </div>
            </div>
        </div>

        <!-- RIGHT COLUMN: Contact Form Wrapper -->
        <div class="contact-form-column">
            <div class="form-wrapper shadow-lg bg-glass rounded-3 p-4 p-md-5">
                <h3 class="mb-4 fw-bold">Send Me a Message</h3>

                <!-- 🔹 SUCCESS FEEDBACK -->
                @if (TempData["ContactSuccess"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 p-3 mb-4 d-flex align-items-center" role="alert" style="background-color: rgba(40, 167, 69, 0.15); color: #198754;">
                        <i class="fa-solid fa-circle-check fa-lg me-2"></i>
                        <div class="fw-semibold">@TempData["ContactSuccess"]</div>
                        <button type="button" class="btn-close ms-auto shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Contact" asp-controller="Home" method="post" class="contact-form">
                    
                    <div class="form-group row g-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label fw-semibold">First Name</label>
                            <input asp-for="FirstName" class="form-control rounded-3" placeholder="John" required>
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label fw-semibold">Last Name</label>
                            <input asp-for="LastName" class="form-control rounded-3" placeholder="Doe" required>
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                        <input asp-for="Email" class="form-control rounded-3" placeholder="john@example.com" required>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Subject" class="form-label fw-semibold">Topic / Subject</label>
                        <select asp-for="Subject" class="form-control rounded-3" required>
                            <option value="">Select a topic...</option>
                            <option value="Research Collaboration">Research Collaboration</option>
                            <option value="Speaking Engagement">Speaking Engagement</option>
                            <option value="Mentoring Question">Mentoring Question</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Subject" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="MessageText" class="form-label fw-semibold">Your Message</label>
                        <textarea asp-for="MessageText" rows="5" class="form-control rounded-3" placeholder="How can I help you?" required></textarea>
                        <span asp-validation-for="MessageText" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn-submit w-100 rounded-pill py-3 fw-bold d-flex align-items-center justify-content-center">
                        <span>Send Message</span>
                        <i class="fa-solid fa-arrow-right ms-2"></i>
                    </button>

                    <p class="form-disclaimer mt-3 text-muted text-center" style="font-size: 0.8rem; font-style: italic;">
                        * Your message will be securely stored and delivered to Dr. Mansi Bhatnagar.
                    </p>

                </form>
            </div>
        </div>

    </div>
</section>

<style>
    .bg-glass {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
    }
    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }
    .btn-submit {
        background: #0d6efd;
        color: white;
        border: none;
        transition: background 0.2s ease, transform 0.2s ease;
    }
    .btn-submit:hover {
        background: #0b5ed7;
        transform: translateY(-2px);
    }
</style>
