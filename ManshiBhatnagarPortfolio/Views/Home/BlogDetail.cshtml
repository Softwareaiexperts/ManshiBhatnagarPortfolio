@model Article

<section class="blog-page-bg">
    <div class="blog-container">

        <!-- 🔹 LEFT: ARTICLE CONTENT -->
        <div class="blog-feed">

            <article class="blog-post-card">

                <div class="blog-post-content">

                    <!-- Category -->
                    <span class="blog-tag">
                        @Model.Category?.ToUpper()
                    </span>

                    <!-- Title -->
                    <div class="article-header">
                        <h1>@Model.Title</h1>

                        <!-- Author -->
                        <div class="author-plate">
                            <img src="~/staticimage/hero_section_img.jpg" class="author-avatar" />

                            <div class="author-info">
                                <h5>@Model.Author</h5>
                                <span>
                                    @Model.CreatedDate.ToString("MMMM dd, yyyy") •
                                    @Model.ReadTime min read
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Main Image -->
                    <img src="@Model.ImageUrl" class="article-main-image" />

                    <!-- Content -->
                    <div class="article-body">
                        @Html.Raw(Model.Content)
                    </div>

                </div>

            </article>

        </div>
    </div>
</section>

