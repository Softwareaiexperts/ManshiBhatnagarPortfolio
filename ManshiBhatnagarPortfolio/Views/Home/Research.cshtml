@{
    ViewData["Title"] = "Research";
    var s = (Dictionary<string, string>)ViewBag.Sections;
}
<link href="~/css/researchpage.css" rel="stylesheet" />
<section class="hero-section">
    <div class="hero-container">
        <h1 class="hero-title">@s.GetValueOrDefault("research_hero_title", "Research")</h1>
    </div>
    <!-- SVG Wavy Divider -->
    <div class="custom-shape-divider-bottom">
        <svg data-name="Layer 1" xmlns="http://w3.org" viewBox="0 0 1200 120" preserveAspectRatio="none">
            <path d="M985.66,92.83C906.67,72,823.78,31,743.84,14.19c-82.26-17.34-168.06-16.33-250.45.39-57.84,11.73-114,31.07-172,41.86A600.21,600.21,0,0,1,0,27.35V120H1200V95.8C1132.19,118.92,1055.71,111.31,985.66,92.83Z" class="shape-fill"></path>
        </svg>
    </div>
</section>

<section class="research-content">
    <div class="container">
        <div class="image-column">
            <div class="image-wrapper">
                <img src="@s.GetValueOrDefault("research_1_image", "/staticimage/hero_section_img.jpg")" alt="Research Area 1">
            </div>
        </div>
        <div class="text-column">
            <h2>@s.GetValueOrDefault("research_1_heading", "Deep Learning & Smart Grid Optimization")</h2>
            <p>@s.GetValueOrDefault("research_1_text", "")</p>
            <a href="#" class="btn-learn">Learn More</a>
        </div>
    </div>
</section>
<!-- Second Research Section -->
<section class="research-content secondary-bg">
    <div class="container reverse">
        <div class="text-column">
            <h2>@s.GetValueOrDefault("research_2_heading", "Integrating Renewable Energy into Microgrids")</h2>
            <p>@s.GetValueOrDefault("research_2_text", "")</p>
            <a href="#" class="btn-learn">Learn More</a>
        </div>
        <div class="image-column">
            <div class="image-wrapper">
                <img src="@s.GetValueOrDefault("research_2_image", "/staticimage/hero_section_img.jpg")" alt="Research Area 2">
            </div>
        </div>
    </div>
</section>
