@model List<Article>
@{
    ViewData["Title"] = "Home Page";
    var s = (Dictionary<string, string>)ViewBag.Sections;
}
<!-- Make sure to link HomePage.css -->
<link href="~/css/HomePage.css" rel="stylesheet" />

<!-- Premium Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-lg-6 hero-content">
                <span class="text-uppercase mb-3 d-block" style="color: var(--blush-pink); font-weight: 700; letter-spacing: 2px;">@s.GetValueOrDefault("about_hero_tagline", "Welcome into my world")</span>
                <h1 class="display-3">@s.GetValueOrDefault("about_hero_name", "Mansi Bhatnagar")</h1>
                <p class="lead mb-4">@s.GetValueOrDefault("about_hero_subtitle", "Ph.D. Scholar & AI Researcher")</p>
                <a href="/Home/Research" class="btn cta-button px-5 py-3">Explore My Research</a>
            </div>

            <div class="col-lg-6 mt-5 mt-lg-0 hero-image-pane text-center">
                <img src="@s.GetValueOrDefault("about_hero_image", "/staticimage/hero_section_img.jpg")" class="organic-image" alt="@s.GetValueOrDefault("about_hero_name", "Mansi Bhatnagar")" style="width: 80%; max-width: 500px;" />
            </div>

        </div>
    </div>
</section>

<!-- Introduction / About -->
<section class="section-premium alt-bg">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5">
                <div class="position-relative">
                    <img src="@s.GetValueOrDefault("about_intro_image", "/staticimage/hero_section_img.jpg")" class="img-fluid rounded-4 collage-img w-100" alt="About Mansi">
                    <!-- Floating Stat Card -->
                    <div class="position-absolute bottom-0 end-0 m-4 p-4 glass-card text-center" style="transform: translate(20px, 20px);">
                        <h3 style="color: var(--rose-gold); margin: 0;">@s.GetValueOrDefault("about_stat_number", "5+")</h3>
                        <p class="small mb-0" style="color: #666; font-weight: 600;">@s.GetValueOrDefault("about_stat_label", "Years of AI Research")</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-7 ps-lg-5">
                <h2 class="display-5 mb-4">@s.GetValueOrDefault("about_intro_heading", "Bridging AI with Sustainable Infrastructure")</h2>
                <div class="fs-5 text-secondary" style="line-height: 1.8;">
                    @Html.Raw(s.GetValueOrDefault("about_intro_text", ""))
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Mission Cards -->
<section class="section-premium">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-4">@s.GetValueOrDefault("about_mission_heading", "My Core Mission")</h2>
            <p class="lead text-secondary mx-auto" style="max-width: 700px;">@s.GetValueOrDefault("about_mission_subtitle", "")</p>
        </div>

        <div class="row g-4">
            @for (int i = 1; i <= 3; i++)
            {
                <div class="col-md-4">
                    <div class="mission-card" style="@(i == 2 ? "transform: translateY(-20px);" : "")">
                        <img src="@s.GetValueOrDefault($"about_mission_{i}_image", "/staticimage/hero_section_img.jpg")" alt="@s.GetValueOrDefault($"about_mission_{i}_title", "")">
                        <h4>@s.GetValueOrDefault($"about_mission_{i}_title", "")</h4>
                        <p>@s.GetValueOrDefault($"about_mission_{i}_text", "")</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Recent Blogs -->
<section class="section-premium alt-bg">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <span class="blog-tag">LATEST INSIGHTS</span>
                <h2 class="display-5">Read My Blog</h2>
            </div>
            <a href="/Home/Blog" class="btn btn-outline-dark rounded-pill px-4" style="border-color: var(--dark-charcoal);">
                View All Posts
            </a>
        </div>

        <div class="row g-4">

            @foreach (var item in Model)
            {
                <div class="col-md-4">
                    <a href="/Home/BlogDetail/@item.Id" style="text-decoration:none; color:inherit;">
                        <div class="premium-blog-card">

                            <!-- 🔹 Dynamic Image -->
                            <img src="@item.ImageUrl" alt="@item.Title">

                            <div class="blog-body">

                                <!-- 🔹 Category -->
                                <span class="blog-tag">@item.Category</span>

                                <!-- 🔹 Title -->
                                <h5>@item.Title</h5>

                                <!-- 🔹 Date -->
                                <p class="text-muted small">
                                    @item.CreatedDate.ToString("MMMM yyyy")
                                </p>

                            </div>
                        </div>
                    </a>
                </div>
            }

        </div>
    </div>
</section>
