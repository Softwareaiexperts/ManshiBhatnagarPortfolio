@model ManshiBhatnagarPortfolio.Models.AdminDashboardViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<!-- Success Message -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Notification Banner -->
@if (Model.UnreadMessagesCount > 0)
{
    <div class="admin-notification">
        <div class="notif-icon">
            <i class="fa-solid fa-bell"></i>
        </div>
        <div class="flex-grow-1">
            <strong>@Model.UnreadMessagesCount new message@(Model.UnreadMessagesCount > 1 ? "s" : "")</strong>
            <span class="text-muted ms-1">— Check what collaborators and students have sent you.</span>
        </div>
        <button class="btn btn-sm btn-warning fw-bold rounded-pill px-3" onclick="document.getElementById('messages-tab').click();">
            <i class="fa-solid fa-envelope-open-text me-1"></i> Open
        </button>
    </div>
}

<!-- Stat Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="stat-card purple">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="stat-icon purple"><i class="fa-solid fa-newspaper"></i></div>
            </div>
            <div class="stat-number">@Model.Articles.Count</div>
            <div class="stat-label">Blog Articles</div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card teal">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="stat-icon teal"><i class="fa-solid fa-images"></i></div>
            </div>
            <div class="stat-number">@Model.GalleryImages.Count</div>
            <div class="stat-label">Gallery Images</div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card rose">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="stat-icon rose"><i class="fa-solid fa-envelope"></i></div>
            </div>
            <div class="stat-number">@Model.ContactMessages.Count</div>
            <div class="stat-label">Total Messages</div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card amber">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="stat-icon amber"><i class="fa-solid fa-bell"></i></div>
            </div>
            <div class="stat-number">@Model.UnreadMessagesCount</div>
            <div class="stat-label">Unread Messages</div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="quick-action-card">
            <div class="quick-action-icon" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">
                <i class="fa-solid fa-pen-nib"></i>
            </div>
            <h6 class="fw-bold mb-1">Create Blog Post</h6>
            <p class="text-muted small mb-3">Draft and publish a new article</p>
            <a href="/Admin/Create" class="btn btn-sm btn-success rounded-pill px-4">
                <i class="fa-solid fa-plus me-1"></i> New Blog
            </a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="quick-action-card">
            <div class="quick-action-icon" style="background: rgba(8, 145, 178, 0.1); color: #0891b2;">
                <i class="fa-solid fa-images"></i>
            </div>
            <h6 class="fw-bold mb-1">Upload Gallery Image</h6>
            <p class="text-muted small mb-3">Add event photos and milestones</p>
            <a href="/Admin/AddImage" class="btn btn-sm btn-info text-white rounded-pill px-4">
                <i class="fa-solid fa-upload me-1"></i> Upload
            </a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="quick-action-card">
            <div class="quick-action-icon" style="background: rgba(108, 92, 231, 0.1); color: #6c5ce7;">
                <i class="fa-solid fa-pen-to-square"></i>
            </div>
            <h6 class="fw-bold mb-1">Edit Pages</h6>
            <p class="text-muted small mb-3">Update About, CV, or Research pages</p>
            <a href="/Admin/EditAbout" class="btn btn-sm rounded-pill px-4" style="background: #6c5ce7; color: #fff;">
                <i class="fa-solid fa-edit me-1"></i> Edit Pages
            </a>
        </div>
    </div>
</div>

<!-- Tabs for Content -->
<div class="admin-card">
    <div class="admin-card-header">
        <ul class="nav admin-tabs" id="adminTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="blogs-tab" data-bs-toggle="tab" data-bs-target="#blogs" type="button" role="tab">
                    <i class="fa-regular fa-newspaper me-1"></i> Blogs (@Model.Articles.Count)
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="gallery-tab" data-bs-toggle="tab" data-bs-target="#gallery" type="button" role="tab">
                    <i class="fa-regular fa-images me-1"></i> Gallery (@Model.GalleryImages.Count)
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link position-relative" id="messages-tab" data-bs-toggle="tab" data-bs-target="#messages" type="button" role="tab">
                    <i class="fa-regular fa-envelope me-1"></i> Messages (@Model.ContactMessages.Count)
                    @if (Model.UnreadMessagesCount > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem;">
                            @Model.UnreadMessagesCount
                        </span>
                    }
                </button>
            </li>
        </ul>
    </div>

    <div class="tab-content" id="adminTabsContent">
        <!-- Blogs Tab -->
        <div class="tab-pane fade show active" id="blogs" role="tabpanel">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th style="padding-left: 24px;">Image</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Date</th>
                        <th style="text-align: right; padding-right: 24px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Articles.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted p-5">
                                <i class="fa-regular fa-file-lines fa-3x mb-3 text-secondary"></i>
                                <h6>No articles yet</h6>
                                <a href="/Admin/Create" class="btn btn-sm btn-success mt-2 rounded-pill px-3">Create First Blog</a>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Articles)
                        {
                            <tr>
                                <td style="padding-left: 24px;">
                                    <div class="rounded-3 overflow-hidden" style="width: 56px; height: 40px;">
                                        <img src="@item.ImageUrl" class="w-100 h-100" style="object-fit: cover;" alt="@item.Title" />
                                    </div>
                                </td>
                                <td class="fw-semibold">@item.Title</td>
                                <td><span class="badge rounded-pill px-3 py-2" style="background: rgba(108,92,231,0.1); color: #6c5ce7;">@item.Category</span></td>
                                <td class="text-muted">@item.CreatedDate.ToString("dd MMM yyyy")</td>
                                <td style="text-align: right; padding-right: 24px;">
                                    <a href="/Admin/Edit/@item.Id" class="btn-admin-edit me-1"><i class="fa-solid fa-pen me-1"></i>Edit</a>
                                    <a href="/Admin/DeleteArtical/@item.Id" class="btn-admin-delete" onclick="return confirm('Delete this article?');"><i class="fa-solid fa-trash me-1"></i>Delete</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Gallery Tab -->
        <div class="tab-pane fade" id="gallery" role="tabpanel">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th style="padding-left: 24px;">Image</th>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Date</th>
                        <th style="text-align: right; padding-right: 24px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.GalleryImages.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted p-5">
                                <i class="fa-regular fa-image fa-3x mb-3 text-secondary"></i>
                                <h6>No gallery images yet</h6>
                                <a href="/Admin/AddImage" class="btn btn-sm btn-info text-white mt-2 rounded-pill px-3">Upload First Image</a>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.GalleryImages)
                        {
                            <tr>
                                <td style="padding-left: 24px;">
                                    <div class="rounded-3 overflow-hidden" style="width: 72px; height: 48px;">
                                        <img src="@item.ImageUrl" class="w-100 h-100" style="object-fit: cover;" alt="@item.Title" />
                                    </div>
                                </td>
                                <td class="fw-semibold">@item.Title</td>
                                <td class="text-muted" style="max-width: 300px;">
                                    @(string.IsNullOrEmpty(item.Description) ? "—" : (item.Description.Length > 80 ? item.Description.Substring(0, 80) + "..." : item.Description))
                                </td>
                                <td class="text-muted">@item.CreatedDate.ToString("dd MMM yyyy")</td>
                                <td style="text-align: right; padding-right: 24px;">
                                    <a href="/Admin/EditImage/@item.Id" class="btn-admin-edit me-1"><i class="fa-solid fa-pen me-1"></i>Edit</a>
                                    <a href="/Admin/DeleteImage/@item.Id" class="btn-admin-delete" onclick="return confirm('Delete this image?');"><i class="fa-solid fa-trash me-1"></i>Delete</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Messages Tab -->
        <div class="tab-pane fade" id="messages" role="tabpanel">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th style="padding-left: 24px; width: 40px;"></th>
                        <th>Sender</th>
                        <th>Subject & Brief</th>
                        <th>Date</th>
                        <th style="text-align: right; padding-right: 24px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.ContactMessages.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted p-5">
                                <i class="fa-regular fa-envelope-open fa-3x mb-3 text-secondary"></i>
                                <h6>Inbox is empty</h6>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.ContactMessages)
                        {
                            <tr class="@(item.IsRead ? "text-muted" : "msg-unread")"
                                style="cursor: pointer;"
                                data-bs-toggle="collapse"
                                data-bs-target="#msg-@item.Id">
                                <td style="padding-left: 24px; text-align: center;">
                                    @if (item.IsRead)
                                    {
                                        <i class="fa-regular fa-envelope-open text-muted"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-envelope" style="color: #6c5ce7;"></i>
                                    }
                                </td>
                                <td>
                                    <div>@item.FirstName @item.LastName</div>
                                    <small class="text-muted fw-normal">@item.Email</small>
                                </td>
                                <td style="max-width: 400px;">
                                    <div class="fw-semibold">@item.Subject</div>
                                    <small class="text-muted fw-normal">@(item.MessageText.Length > 80 ? item.MessageText.Substring(0, 80) + "..." : item.MessageText)</small>
                                </td>
                                <td><small>@item.CreatedDate.ToString("dd MMM yyyy, hh:mm tt")</small></td>
                                <td style="text-align: right; padding-right: 24px;" onclick="event.stopPropagation();">
                                    <div class="d-flex justify-content-end gap-1">
                                        @if (!item.IsRead)
                                        {
                                            <form asp-action="MarkMessageRead" asp-route-id="@item.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn-admin-success" title="Mark as Read"><i class="fa-solid fa-check"></i></button>
                                            </form>
                                        }
                                        <form asp-action="DeleteMessage" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this message?');">
                                            <button type="submit" class="btn-admin-delete" title="Delete"><i class="fa-solid fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <!-- Expandable message detail -->
                            <tr class="border-0">
                                <td colspan="5" class="p-0 border-0">
                                    <div class="collapse" id="msg-@item.Id">
                                        <div class="p-4 m-3 rounded-3 bg-light border" style="border-left: 4px solid #6c5ce7 !important;">
                                            <div class="d-flex justify-content-between mb-2">
                                                <div>
                                                    <h6 class="fw-bold mb-0">@item.FirstName @item.LastName</h6>
                                                    <a href="mailto:@item.Email" class="small text-decoration-none"><i class="fa-regular fa-paper-plane me-1"></i>@item.Email</a>
                                                </div>
                                                <span class="badge rounded-pill px-3 py-2 h-100" style="background: #6c5ce7; color: #fff;">@item.Subject</span>
                                            </div>
                                            <hr class="opacity-25" />
                                            <p class="bg-white p-3 rounded border small mb-0" style="white-space: pre-wrap; line-height: 1.7;">@item.MessageText</p>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>