@model Article
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Article";
}

<div class="editor-section">
    <h5><i class="fa-solid fa-pen-to-square"></i> Article Details</h5>
    
    <form asp-controller="Admin" asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedDate" />
        <input type="hidden" asp-for="ImageUrl" />

        <div class="row g-3">
            
            <div class="col-12">
                <label class="form-label-admin">Title</label>
                <input asp-for="Title" class="form-control form-control-admin" placeholder="Enter article title" required />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label-admin">Author</label>
                <input asp-for="Author" class="form-control form-control-admin" placeholder="e.g. Dr. Mansi Bhatnagar" required />
                <span asp-validation-for="Author" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label-admin">Category</label>
                <input asp-for="Category" class="form-control form-control-admin" placeholder="e.g. Computer Vision, Deep Learning" required />
                <span asp-validation-for="Category" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label-admin">Read Time (minutes)</label>
                <input asp-for="ReadTime" type="number" class="form-control form-control-admin" placeholder="e.g. 5" required />
                <span asp-validation-for="ReadTime" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label-admin">Change Image</label>
                <div class="d-flex align-items-center gap-3">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="img-preview-admin" alt="Current Image" />
                    }
                    <input type="file" name="imageFile" class="form-control form-control-admin" accept="image/*" />
                </div>
            </div>

            <div class="col-12">
                <label class="form-label-admin">Content</label>
                <textarea asp-for="Content" id="editor" class="form-control"></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

        </div>

        <div class="text-end mt-4 pt-3 border-top">
            <a href="/Admin" class="btn btn-light rounded-pill px-4 me-2">Cancel</a>
            <button type="submit" class="btn-save-page">
                <i class="fa-solid fa-floppy-disk me-2"></i>Save Changes
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#editor').summernote({
                height: 350,
                toolbar: [
                    ['style', ['style', 'bold', 'italic', 'underline', 'clear']],
                    ['font', ['strikethrough', 'superscript', 'subscript']],
                    ['color', ['color']],
                    ['para', ['ul', 'ol', 'paragraph']],
                    ['insert', ['link', 'picture', 'video', 'table']],
                    ['view', ['fullscreen', 'codeview', 'help']]
                ]
            });
        });
    </script>
}