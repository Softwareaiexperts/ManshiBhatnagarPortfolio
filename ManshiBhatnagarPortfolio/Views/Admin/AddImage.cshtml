@model GalleryImage
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Upload Gallery Image";
}

<div class="editor-section">
    <h5><i class="fa-solid fa-cloud-arrow-up"></i> Upload Details</h5>
    
    <form asp-action="AddImage" method="post" enctype="multipart/form-data">
        <div class="row g-3">
            
            <div class="col-md-6">
                <label class="form-label-admin">Select Image File</label>
                <input type="file" name="file" class="form-control form-control-admin" onchange="previewImage(event)" accept="image/*" required />
                <div class="form-text">Supported formats: .jpg, .png, .jpeg, .webp</div>
            </div>

            <div class="col-md-6 text-center">
                <label class="form-label-admin d-block">Image Preview</label>
                <div class="image-preview-container d-inline-block rounded-3 overflow-hidden shadow-sm" style="background-color: #f8f9fa; border: 2px dashed #dee2e6; padding: 6px; min-height: 120px; min-width: 180px; max-width: 100%;">
                    <img id="preview" src="#" style="max-height: 120px; max-width: 100%; display: none; object-fit: contain;" />
                    <div id="preview-placeholder" class="d-flex flex-column align-items-center justify-content-center h-100 py-3 text-muted">
                        <i class="fa-regular fa-image fa-2x mb-1 text-secondary-light"></i>
                        <span class="small" style="font-size:0.75rem;">No file chosen</span>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <label class="form-label-admin">Image Title</label>
                <input asp-for="Title" class="form-control form-control-admin" placeholder="e.g. Keynote Speech at AI Summit" required />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label class="form-label-admin">Description / Caption</label>
                <textarea asp-for="Description" class="form-control form-control-admin" rows="4" placeholder="Describe the seminar, bootcamp, or research activity..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

        </div>

        <div class="text-end mt-4 pt-3 border-top">
            <a href="/Admin" class="btn btn-light rounded-pill px-4 me-2">Cancel</a>
            <button type="submit" class="btn-save-page">
                <i class="fa-solid fa-cloud-arrow-up me-2"></i>Upload Image
            </button>
        </div>
    </form>
</div>

<!-- Image Preview Script -->
<script>
    function previewImage(event) {
        var input = event.target;
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) {
                var output = document.getElementById('preview');
                var placeholder = document.getElementById('preview-placeholder');
                
                output.src = e.target.result;
                output.style.display = 'inline-block';
                placeholder.style.setProperty('display', 'none', 'important');
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>